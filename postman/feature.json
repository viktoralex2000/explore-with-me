              "});",
              "",
              "pm.test(\"Comment should have state PENDING\", function () {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.length > 0) {",
              "        pm.expect(jsonData[0]).to.have.property('state');",
              "        pm.expect(jsonData[0].state).to.eql('PENDING');",
              "    }",
              "});",
              "",
              "// Store comment id for next tests if not already stored",
              "const jsonData = pm.response.json();",
              "if (jsonData.length > 0 && !pm.environment.get(\"commentId\")) {",
              "    pm.environment.set(\"commentId\", jsonData[0].id);",
              "}",
              "if (!pm.environment.get(\"eventId\") && jsonData.length > 0) {",
              "    pm.environment.set(\"eventId\", jsonData[0].eventId);",
              "}"
            ],
